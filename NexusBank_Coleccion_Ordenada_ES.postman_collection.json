    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.token) {",
                  "  pm.collectionVariables.set('adminToken', body.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"adminb@nexusbank.com\",\n  \"password\": \"ADMINB\"\n}"
            },
            "url": "{{baseUrl}}/{{apiVersion}}/auth/login"
          }
        },
        {
          "name": "Login Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.token) {",
                  "  pm.collectionVariables.set('clientToken', body.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente.demo@nexusbank.com\",\n  \"password\": \"Cliente123!\"\n}"
            },
            "url": "{{baseUrl}}/{{apiVersion}}/auth/login"
